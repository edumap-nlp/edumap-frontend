# EduMap Environment Variables

# Azure OpenAI (primary — set these for Azure deployments)
OPENAI_API_KEY='''
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_DEPLOYMENT_NAME=gpt-5
OPENAI_API_VERSION=2025-01-01-preview

# Standard OpenAI (no OPENAI_ENDPOINT): optional override of the model name.
# The frontend may ship newer model names (e.g. gpt-5.2) that your account
# doesn't have access to yet. Set OPENAI_MODEL to pin a known-good one.
# OPENAI_MODEL=gpt-5

# Server
PORT=3001

# Frontend (set in Vite)
VITE_API_BASE=http://localhost:3001/api
